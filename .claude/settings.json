{
  "permissions": {
    "allow": [
      "mcp__trek__list_trips",
      "mcp__trek__get_trip_summary",
      "mcp__trek__create_trip",
      "mcp__trek__update_trip",
      "mcp__trek__create_place",
      "mcp__trek__update_place",
      "mcp__trek__delete_place",
      "mcp__trek__assign_place_to_day",
      "mcp__trek__unassign_place",
      "mcp__trek__reorder_day_assignments",
      "mcp__trek__update_assignment_time",
      "mcp__trek__update_day",
      "mcp__trek__create_day_note",
      "mcp__trek__update_day_note",
      "mcp__trek__delete_day_note",
      "mcp__trek__create_budget_item",
      "mcp__trek__update_budget_item",
      "mcp__trek__delete_budget_item",
      "mcp__trek__create_packing_item",
      "mcp__trek__update_packing_item",
      "mcp__trek__toggle_packing_item",
      "mcp__trek__delete_packing_item",
      "mcp__trek__create_reservation",
      "mcp__trek__update_reservation",
      "mcp__trek__delete_reservation",
      "mcp__trek__link_hotel_accommodation",
      "mcp__trek__create_collab_note",
      "mcp__trek__update_collab_note",
      "mcp__trek__delete_collab_note",
      "mcp__trek__create_bucket_list_item",
      "mcp__trek__delete_bucket_list_item",
      "mcp__trek__mark_country_visited",
      "mcp__trek__unmark_country_visited",
      "mcp__google-maps__maps_search_places",
      "mcp__google-maps__maps_place_details",
      "mcp__google-maps__maps_directions",
      "mcp__google-maps__maps_distance_matrix",
      "mcp__google-maps__maps_geocode",
      "mcp__google-maps__maps_reverse_geocode",
      "mcp__google-maps__maps_elevation",
      "mcp__airbnb__airbnb_search",
      "mcp__airbnb__airbnb_listing_details"
    ]
  },
  "mcpServers": {
    "airbnb": {
      "command": "npx",
      "args": [
        "-y",
        "@openbnb/mcp-server-airbnb"
      ]
    },
    "google-maps": {
      "command": "bash",
      "args": [
        "core/google-maps-mcp.sh"
      ]
    },
    "trek": {
      "command": "bash",
      "args": [
        "core/trek-mcp.sh"
      ]
    }
  }
}
